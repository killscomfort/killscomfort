# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GTM_ID=

# Email (Resend) — https://resend.com/api-keys
# Verify killscomfort.com in Resend, then use orders@killscomfort.com as sender
RESEND_API_KEY=re_xxxxxxxx
INQUIRY_NOTIFICATION_EMAIL=Killscomfort@gmail.com
ORDERS_NOTIFICATION_EMAIL=Killscomfort@gmail.com
EMAIL_FROM=KillsComfort <orders@killscomfort.com>

# PayPal — mock works locally without credentials; use sandbox/live for real payments
PAYPAL_MODE=mock
NEXT_PUBLIC_PAYPAL_MODE=mock
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Stripe — donations at /donate (enable Apple Pay & Google Pay in Stripe Dashboard → Payment methods)
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# Printful dropship automation
PRINTFUL_API_KEY=pfk_xxxxxxxx
# Printful variant IDs are configured in src/lib/merch-printful.ts

# Apple Pay (PayPal) — sandbox domain file is bundled; register www.killscomfort.com in PayPal → Manage Apple Pay
APPLE_PAY_DOMAIN_NAME=www.killscomfort.com
# APPLE_PAY_DOMAIN_ASSOCIATION=   # optional override from PayPal dashboard download
